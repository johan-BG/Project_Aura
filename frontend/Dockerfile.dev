FROM node:20-alpine

WORKDIR /app

COPY package*.json ./

# Install all dependencies (including devDependencies needed for local dev)
RUN npm install --legacy-peer-deps

# We copy the rest of the code, but docker-compose will overwrite this 
# with a live volume mount for hot-reloading.
COPY . .

EXPOSE 3000

# Run Next.js in development mode
CMD ["npm", "run", "dev"]